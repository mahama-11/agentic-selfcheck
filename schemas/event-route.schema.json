{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EventRoute",
  "type": "object",
  "required": ["id", "event", "description", "feature", "groups", "mode"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "event": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "feature": {"type": "string"},
    "groups": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "mode": {"type": "string", "enum": ["event", "watchdog"]},
    "strict_audit": {"type": "boolean"},
    "debounce_seconds": {"type": "integer", "minimum": 0},
    "allowed_sources": {"type": "array", "items": {"type": "string"}},
    "human_escalation": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
