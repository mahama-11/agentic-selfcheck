{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Capability",
  "type": "object",
  "required": ["id", "description", "contracts", "verifiers"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "description": {"type": "string"},
    "contracts": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "verifiers": {"type": "array", "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"}},
    "human_boundaries": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
