{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GitHubPRAutonomyPolicy",
  "type": "object",
  "required": ["id", "description", "defaults", "repositories", "states", "terminal_states"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "description": {"type": "string"},
    "version": {"type": "integer", "minimum": 1},
    "defaults": {
      "type": "object",
      "required": ["dry_run", "unknown_repo", "unknown_action", "high_risk_requires_human", "max_repair_attempts", "auto_merge"],
      "properties": {
        "dry_run": {"type": "boolean"},
        "unknown_repo": {"enum": ["ignored", "blocked"]},
        "unknown_action": {"enum": ["ignored", "blocked"]},
        "high_risk_requires_human": {"type": "boolean"},
        "max_repair_attempts": {"type": "integer", "minimum": 0, "maximum": 10},
        "auto_merge": {
          "type": "object",
          "required": ["enabled"],
          "properties": {
            "enabled": {"type": "boolean"},
            "allowed_risks": {"type": "array", "items": {"enum": ["low", "medium", "high"]}},
            "method": {"enum": ["squash", "merge", "rebase"]},
            "delete_branch": {"type": "boolean"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "states": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "terminal_states": {"type": "array", "minItems": 1, "items": {"enum": ["PASS", "PASS_WITH_NOTES", "READY_FOR_HUMAN", "NEEDS_HUMAN", "BLOCKED", "IGNORED", "MERGED"]}},
    "repositories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "owner", "name", "base_branches", "required_checks", "risk", "repair", "merge"],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
          "owner": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "base_branches": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "required_checks": {"type": "array", "items": {"type": "string"}},
          "selfcheck": {
            "type": "object",
            "properties": {
              "feature": {"type": "string"},
              "groups": {"type": "array", "items": {"type": "string"}}
            },
            "additionalProperties": false
          },
          "risk": {
            "type": "object",
            "required": ["high_globs", "medium_globs", "large_diff_file_limit"],
            "properties": {
              "high_globs": {"type": "array", "items": {"type": "string"}},
              "medium_globs": {"type": "array", "items": {"type": "string"}},
              "large_diff_file_limit": {"type": "integer", "minimum": 1}
            },
            "additionalProperties": false
          },
          "repair": {
            "type": "object",
            "required": ["enabled", "max_attempts", "allowed_globs", "denied_globs"],
            "properties": {
              "enabled": {"type": "boolean"},
              "execution_enabled": {"type": "boolean"},
              "max_attempts": {"type": "integer", "minimum": 0, "maximum": 10},
              "fixers": {"type": "array", "items": {"enum": ["markdown-marker", "gofmt"]}},
              "allowed_risks": {"type": "array", "items": {"enum": ["low", "medium", "high"]}},
              "allowed_globs": {"type": "array", "items": {"type": "string"}},
              "denied_globs": {"type": "array", "items": {"type": "string"}}
            },
            "additionalProperties": false
          },
          "merge": {
            "type": "object",
            "required": ["auto_merge_enabled", "require_human_approval", "allowed_methods"],
            "properties": {
              "auto_merge_enabled": {"type": "boolean"},
              "require_human_approval": {"type": "boolean"},
              "allowed_methods": {"type": "array", "minItems": 1, "items": {"enum": ["squash", "merge", "rebase"]}},
              "delete_branch": {"type": "boolean"}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
